# V2 Entity Validation Configuration
# Copy this to .env and fill in your database details

# Database Connection (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=syncrosale
DB_USER=postgres
DB_PASSWORD=your_password_here

# Optional: Query timeout (milliseconds)
# DB_QUERY_TIMEOUT=30000

# Optional: Connection pool settings
# DB_POOL_MAX=2
# DB_POOL_IDLE_TIMEOUT=2000
